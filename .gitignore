.DS_Store
*.log

# Godot Web/PWA export output (regenerated by deploy.yml / verify.sh; never tracked)
build/

# headless loop runtime (process/loop.sh)
loop.err

# review artifacts (regenerable)
.screenshots/

# Licensed dog asset — NEVER commit (ADR-0002/0006). The CC0 placeholder
# assets/models/dog.glb IS tracked; the licensed source/staging forms are not.
# (ADR-0006 ships the licensed model as an encrypted .pck built in CI from a
# secret-injected .glb — that asset never lands in this public repo.)
models-build/
*.fbx
# Local-dev copy of the licensed Labrador, placed where Godot can import it so the dog
# actually sits in dev. Still NEVER committed — public deploy gets it via the ADR-0006
# encrypted pack, not this plain glb. main.gd loads it when present, else the CC0 dog.
# Broad glob: covers the glb, its .import, AND the textures Godot's importer extracts
# out of it (dog_licensed_Labrador_Albedo.png, dog_licensed_Texture.png, …). All licensed.
assets/models/dog_licensed*
# ...EXCEPT the AES-256-encrypted blob: ciphertext, not the asset (ADR-0006 is
# deterrence, not DRM). It rides in the repo because the 19 MB glb can't fit a 48 KB
# GitHub secret; deploy-licensed.yml decrypts it in CI with GODOT_SCRIPT_ENCRYPTION_KEY.
# The raw .glb / .import / textures above stay ignored — only this .enc is committed.
!assets/models/dog_licensed.glb.enc

# Godot import cache (regenerated on import; never tracked)
.godot/

# nix
result
result-*
.direnv/

# Playwright for the web capture harness (tools/web_*.mjs) — a symlink to the npx
# cache (~/.npm/_npx/.../node_modules), not a project dep. Never tracked.
node_modules

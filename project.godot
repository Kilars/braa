; Bra! — Godot 4 project (v2 stack: ADR-0001 Godot 4, ADR-0003 GDScript,
; ADR-0004 PWA web export, ADR-0005 repo layout). Scaffold only — Phase 1
; gameplay (sit / mark / score, .docs/specs/) is built in later TDD tasks.
;
; Engine config format version 5 (Godot 4.6.x).

config_version=5

[application]

config/name="Bra!"
config/description="One-tap dog-training timing game (v2). Phase 1: the perfect single mark."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon=""

[display]

; Mobile portrait is the only target (.docs/specs/: mobile-only, phone-portrait).
window/size/viewport_width=720
window/size/viewport_height=1280
window/handheld/orientation="portrait"
window/stretch/mode="canvas_items"
; "expand" (not "keep") so the look-down garden FILLS every phone — modern phones are taller
; than the 720×1280 (9:16) design, and "keep" letterboxed them with black top/bottom bands
; (~16% of a 390×844 screen). "expand" matches the real window aspect: the infinite
; ProceduralSky + grass fill the taller frame, the camera reads the live aspect
; (_viewport_aspect) and re-fits the dog, and the anchor-based UI re-anchors to the new edges.
; See task 063 / PO 2026-07-01. Guarded by tests/test_stretch_aspect.gd.
window/stretch/aspect="expand"

[rendering]

; Single-threaded GL Compatibility (WebGL2) — the web/PWA-compatible renderer
; for GitHub Pages without COOP/COEP isolation (ADR-0001 / ADR-0005).
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
